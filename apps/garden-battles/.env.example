# ---------------------------
# App runtime
# ---------------------------
PORT=5000

# Backend Sui event source (server/routes.ts)
# Run: PRIVATE_KEY=suiprivkey... npx ts-node scripts/deploy-battle.ts
# Then copy the printed IDs here:
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
BATTLE_PACKAGE_ID=0x50864e060caca53c7c50a355f7550276b52f91a0bd1e7b1e54ac9dbb754ef299
BATTLE_EVENT_PACKAGE_ID=0x656ac984c39b952b40ccaaad4c26a3e074c4c99f56e2bac0862b811557de448b
BATTLE_MODULE=battle

# ---------------------------
# Frontend split deployment
# ---------------------------
# Only set when frontend is hosted separately from backend.
VITE_RELAY_URL=https://your-backend-host.example.com

# ---------------------------
# Optional Drizzle tooling only
# ---------------------------
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ---------------------------
# NFT CLI / admin scripts
# ---------------------------
# SUI_NETWORK=testnet
# SUI_PRIVATE_KEY=suiprivkey...
# PRIVATE_KEY=...
# PACKAGE_ID=0x...
# COLLECTION_PACKAGE_ID=0x...
# MINT_CAP_ID=0x...
# POOL_ID=0x...
# BATTLE_PACKAGE_ID=0x...
# CONFIG_ID=0x...
# TREASURY_ADDRESS=0x...
# PINATA_JWT=...
# PINATA_GATEWAY=ipfs://
